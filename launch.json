{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Metro Bundler",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start"],
      "port": 8081
    },
    {
      "name": "Expo Tunnel",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--tunnel"],
      "port": 8081,
      "autoPort": false
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081,
      "autoPort": false
    }
  ]
}
